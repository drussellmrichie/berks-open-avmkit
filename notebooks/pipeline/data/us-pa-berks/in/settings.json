{
  "locality": {
    "name": "Berks County",
    "county": "Berks",
    "state": "PA",
    "slug": "us-pa-berks"
  },
  "data": {
    "load": {
      "geo_parcels": {
        "filename": "berks_parcels.parquet",
        "dupes": {"subset": ["key"], "drop": true},
        "load": {
          "key":                    ["key",                      "str"],
          "land_area_sqft":         ["land_area_sqft",           "float"],
          "bldg_area_finished_sqft":["bldg_area_finished_sqft",  "float"],
          "bldg_year_built":        ["bldg_year_built",          "float"],
          "bldg_condition_num":     ["bldg_condition_num",       "float"],
          "bldg_rooms_bed":         ["bldg_rooms_bed",           "float"],
          "bldg_rooms_bath":        ["bldg_rooms_bath",          "float"],
          "bldg_rooms_bath_half":   ["bldg_rooms_bath_half",     "float"],
          "bldg_stories":           ["bldg_stories",             "float"],
          "bldg_type":              ["bldg_type",                "str"],
          "bldg_ext_wall":          ["bldg_ext_wall",            "str"],
          "bldg_bsmt_type":         ["bldg_bsmt_type",           "str"],
          "bldg_garage_cars":       ["bldg_garage_cars",         "float"],
          "bldg_fireplaces":        ["bldg_fireplaces",          "float"],
          "category_code":          ["category_code",            "str"],
          "neighborhood":           ["neighborhood",             "str"],
          "assr_land_value":        ["assr_land_value",          "float"],
          "assr_impr_value":        ["assr_impr_value",          "float"],
          "assr_market_value":      ["assr_market_value",        "float"],
          "is_vacant":              ["is_vacant",                "bool"],
          "school_district":        ["school_district",          "str"]
        }
      },
      "sales": {
        "filename": "sales.parquet",
        "load": {
          "key_sale":    ["key_sale",    "str"],
          "key":         ["key",         "str"],
          "sale_date":   ["sale_date",   "datetime", "%Y-%m-%d"],
          "sale_price":  ["sale_price",  "float"],
          "valid_sale":  ["valid_sale",  "bool"],
          "vacant_sale": ["vacant_sale", "bool"]
        }
      }
    },
    "process": {
      "merge": {
        "universe": ["geo_parcels"],
        "sales":    [{"id": "sales", "dupes": "allow"}]
      },
      "enrich": {
        "census": {
          "enabled": true,
          "fips": "42011"
        },
        "distances": {
          "enabled": true,
          "parks": {
            "enabled": true,
            "osm": true,
            "max_distance": 2,
            "unit": "km",
            "store_top": false
          },
          "water_bodies": {
            "enabled": true,
            "osm": true,
            "max_distance": 5,
            "unit": "km",
            "store_top": false
          },
          "educational": {
            "enabled": true,
            "osm": true,
            "max_distance": 3,
            "unit": "km",
            "store_top": false
          },
          "transportation": {
            "enabled": true,
            "osm": true,
            "max_distance": 2,
            "unit": "km"
          },
          "highway_on_ramps": {
            "enabled": true,
            "osm": true,
            "osm_tags": {"highway": ["motorway_junction"]},
            "max_distance": 10,
            "unit": "km",
            "store_top": false
          }
        }
      },
      "dupes": {
        "universe": {"subset": ["key"], "drop": true},
        "sales":    {"subset": ["key_sale"], "drop": true}
      },
      "fill": {
        "median_impr": [
          "bldg_condition_num",
          "bldg_stories",
          "bldg_rooms_bath",
          "bldg_rooms_bath_half",
          "bldg_rooms_bed",
          "bldg_garage_cars",
          "bldg_fireplaces"
        ],
        "zero": [
          "bldg_area_finished_sqft"
        ]
      }
    }
  },
  "modeling": {
    "metadata": {
      "valuation_date": "2026-01-01",
      "use_sales_from": 2021,
      "modeler": "MUSA",
      "modeler_nick": "musa"
    },
    "try_variables": {
      "variables": [
        "land_area_sqft",
        "land_area_sqft_log",
        "bldg_area_finished_sqft",
        "bldg_age_years",
        "bldg_condition_num",
        "bldg_rooms_bed",
        "bldg_rooms_bath",
        "bldg_rooms_bath_half",
        "bldg_stories",
        "bldg_garage_cars",
        "bldg_fireplaces",
        "bldg_ext_wall",
        "bldg_bsmt_type",
        "latitude_norm",
        "longitude_norm",
        "polar_angle",
        "polar_radius",
        "geom_rectangularity_num",
        "geom_aspect_ratio",
        "dist_to_cbd",
        "dist_to_osm_parks",
        "dist_to_osm_water_bodies",
        "dist_to_osm_educational",
        "dist_to_osm_highway_on_ramps",
        "median_income",
        "median_g_rent",
        "neighborhood",
        "school_district",
        "bldg_type"
      ]
    },
    "instructions": {
      "main": {
        "run": ["lightgbm"]
      },
      "vacant": {
        "run": ["lightgbm"]
      },
      "hedonic": {
        "run": ["lightgbm"]
      },
      "time_adjustment": {
        "period": "Q"
      },
      "ensemble": [],
      "allocation": []
    },
    "models": {
      "main": {
        "default": {
          "ind_vars": [
            "bldg_area_finished_sqft",
            "land_area_sqft",
            "bldg_condition_num",
            "bldg_age_years",
            "bldg_rooms_bed",
            "bldg_rooms_bath",
            "bldg_rooms_bath_half",
            "bldg_stories",
            "bldg_garage_cars",
            "bldg_fireplaces",
            "bldg_ext_wall",
            "bldg_bsmt_type",
            "dist_to_cbd",
            "dist_to_osm_parks",
            "dist_to_osm_water_bodies",
            "dist_to_osm_educational",
            "dist_to_osm_highway_on_ramps",
            "median_income",
            "median_g_rent",
            "latitude_norm",
            "longitude_norm",
            "polar_radius",
            "polar_angle",
            "geom_aspect_ratio",
            "neighborhood",
            "school_district",
            "bldg_type"
          ]
        }
      },
      "vacant": {
        "default": {
          "ind_vars": [
            "land_area_sqft",
            "land_area_sqft_log",
            "latitude_norm",
            "longitude_norm",
            "polar_angle",
            "polar_radius",
            "geom_rectangularity_num",
            "dist_to_cbd",
            "dist_to_osm_parks",
            "dist_to_osm_water_bodies",
            "dist_to_osm_educational",
            "dist_to_osm_highway_on_ramps",
            "median_income",
            "median_g_rent",
            "neighborhood",
            "school_district",
            "cat_is_residential",
            "cat_is_commercial",
            "cat_is_industrial",
            "cat_is_farm"
          ]
        }
      },
      "hedonic": {
        "default": {
          "ind_vars": [
            "bldg_area_finished_sqft",
            "land_area_sqft",
            "land_area_sqft_log",
            "bldg_condition_num",
            "bldg_age_years",
            "bldg_rooms_bed",
            "bldg_rooms_bath",
            "bldg_rooms_bath_half",
            "bldg_stories",
            "bldg_garage_cars",
            "bldg_fireplaces",
            "bldg_ext_wall",
            "bldg_bsmt_type",
            "bldg_type",
            "dist_to_cbd",
            "dist_to_osm_parks",
            "dist_to_osm_water_bodies",
            "dist_to_osm_educational",
            "dist_to_osm_highway_on_ramps",
            "median_income",
            "median_g_rent",
            "latitude_norm",
            "longitude_norm",
            "polar_radius",
            "polar_angle",
            "geom_aspect_ratio",
            "neighborhood",
            "school_district"
          ]
        }
      }
    },
    "model_groups": {
      "residential_sf": {
        "name": "Residential (CLASS=R)",
        "filter": ["==", "category_code", "str:R"]
      },
      "residential_mf": {
        "name": "Apartment (CLASS=A)",
        "filter": ["==", "category_code", "str:A"]
      },
      "commercial": {
        "name": "Commercial/Industrial (CLASS=C or I)",
        "filter": ["isin", "category_code", ["C", "I"]]
      },
      "vacant": {
        "name": "Vacant land",
        "filter": ["==", "is_vacant", true]
      }
    }
  },
  "analysis": {
    "sales_scrutiny": {
      "location": "neighborhood",
      "fields_categorical": ["category_code"],
      "heuristics_enabled": false
    },
    "ratio_study": {
      "look_back_years": 1,
      "breakdowns": [
        {"by": "sale_price",              "quantiles": 10},
        {"by": "bldg_area_finished_sqft", "quantiles": 10},
        {"by": "bldg_age_years",          "slice_size": 10},
        {"by": "land_area_sqft",          "quantiles": 10},
        {"by": "bldg_condition_num",      "quantiles": 5},
        {"by": "<loc_neighborhood>"},
        {"by": "<loc_market_area>"},
        {"by": "school_district"}
      ]
    }
  },
  "field_classification": {
    "important": {
      "fields": {
        "impr_category":   "bldg_type",
        "land_category":   "category_code",
        "loc_neighborhood":"neighborhood",
        "loc_market_area": "census_tract"
      },
      "locations": [
        "neighborhood",
        "census_tract",
        "school_district"
      ]
    },
    "land": {
      "numeric":     ["land_area_sqft"],
      "categorical": ["neighborhood", "census_tract", "school_district"]
    },
    "impr": {
      "numeric": [
        "bldg_area_finished_sqft",
        "bldg_age_years",
        "bldg_condition_num",
        "bldg_rooms_bed",
        "bldg_rooms_bath",
        "bldg_rooms_bath_half",
        "bldg_stories",
        "bldg_garage_cars",
        "bldg_fireplaces"
      ],
      "categorical": ["bldg_type", "bldg_ext_wall", "bldg_bsmt_type"]
    }
  },
  "data_dictionary": {}
}
